    <body>
        <div class="container">
            <h1>Network Status: <span class="status-badge {'on' if on_vpn else 'off'}">{'SECURE VPN' if on_vpn else 'PUBLIC NET'}</span></h1>
            <p>Your IP: <code>{client_ip}</code></p>
            <hr>
            <h3>Public Endpoint Hits (/status)</h3>
            <canvas id="statusChart" width="600" height="250"></canvas>
            {f'''
            <h3 style="color: #28a745;">Secure Endpoint Hits (/secure-status)</h3>
            <canvas id="secureChart" width="600" height="250"></canvas>
            ''' if on_vpn else '<p style="color: #dc3545; font-weight: bold;">⚠️ Secure metrics are hidden. Connect to WireGuard to view.</p>'}
