from fastapi import FastAPI, Request, HTTPException
from fastapi.responses import HTMLResponse
from random import randint
from threading import Lock
import ipaddress
from datetime import datetime

app = FastAPI()

# Thread-safe counters
counter_status = 0
counter_secure = 0
counter_lock = Lock()

# History for visualization
history_status = []
history_secure = []

# VPN and Management IPs - Templated via Ansible
ALLOWED_IPS = [
    ipaddress.ip_network("10.0.0.0/24"),
    ipaddress.ip_network("{{ hostvars[groups['wireguard'][0]]['private_ip'] }}/32")
]

def is_on_vpn(ip_str):
    client_ip = ipaddress.ip_address(ip_str)
    return any(client_ip in net for net in ALLOWED_IPS)

def record_hit(history_list, is_secure=False):
    """Increments the appropriate counter and returns the shared hit format."""
    global counter_status, counter_secure
    timestamp = datetime.now().strftime("%H:%M:%S")
    
    with counter_lock:
        if is_secure:
            counter_secure += 1
            hits = counter_secure
        else:
            counter_status += 1
            hits = counter_status
        history_list.append({"time": timestamp, "hits": hits})
    
    return {"hits": hits, "random_number": randint(1, 10)}

@app.get("/status")
def status():
    return record_hit(history_status, is_secure=False)

@app.get("/secure-status")
def secure_status(request: Request):
    if not is_on_vpn(request.client.host):
        raise HTTPException(status_code=403, detail="Access denied: must be on VPN")
    return record_hit(history_secure, is_secure=True)

@app.get("/", response_class=HTMLResponse)
def dashboard(request: Request):
    client_ip = request.client.host
    on_vpn = is_on_vpn(client_ip)

    status_labels = [h['time'] for h in history_status]
    status_data = [h['hits'] for h in history_status]
    secure_labels = [h['time'] for h in history_secure]
    secure_data = [h['hits'] for h in history_secure]

{% raw %}
    html_content = f"""
